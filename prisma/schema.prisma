generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model USOrder {
  id              String   @id @default(cuid())
  orderNo         String   @unique
  patientName     String
  usAddress       String
  kakaoId         String?
  prescriptionImg String
  pillDays        Int
  drugName        String
  drugCategory    String?
  isApproved      Boolean  @default(false)
  trackingNo      String?
  paymentMethod   String?
  paymentStatus   String   @default("PENDING")
  stripeSessionId String?
  status          Status   @default(RECEIVED)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  riskLevel       Int      @default(1)
}

model ControlledSubstance {
  id          String   @id @default(cuid())
  name        String   @unique
  riskLevel   Int
  category    String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("admin")
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Status {
  RECEIVED
  VERIFIED
  PREPARED
  SHIPPED
  DELIVERED
}
