generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model USOrder {
  id               String   @id @default(cuid())
  orderNo          String   @unique
  patientName      String
  usAddress        String
  kakaoId          String?
  prescriptionImg  String?
  isConsultation   Boolean  @default(false)
  consultationTime String?
  symptomDesc      String?
  pillDays         Int
  drugName         String
  drugCategory     String?
  isApproved       Boolean  @default(false)
  trackingNo       String?
  paymentMethod    String?
  paymentStatus    String   @default("PENDING")
  stripeSessionId  String?
  status           Status   @default(RECEIVED)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  riskLevel        Int      @default(1)
}

model ControlledSubstance {
  id          String   @id @default(cuid())
  name        String   @unique
  riskLevel   Int
  category    String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  role           String    @default("user")
  usAddress      String?
  allergies      String?
  currentMeds    String?
  pastConditions String?
  kakaoNotif     Boolean   @default(true)
  emailReport    Boolean   @default(false)
  promoUpdates   Boolean   @default(true)
  accounts       Account[]
  sessions       Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Status {
  RECEIVED
  VERIFIED
  PREPARED
  SHIPPED
  DELIVERED
}

model OrangeBookProduct {
  id                String  @id @default(cuid())
  ingredient        String
  dfRoute           String?
  tradeName         String
  applicant         String
  strength          String
  applType          String
  applNo            String
  productNo         String
  teCode            String?
  approvalDate      String?
  rld               String?
  rs                String?
  type              String?
  applicantFullName String?

  @@index([applNo, productNo])
  @@index([tradeName])
  @@index([ingredient, strength])
}

model OrangeBookPatent {
  id                String    @id @default(cuid())
  applType          String
  applNo            String
  productNo         String
  patentNo          String
  patentExpireDate  DateTime?
  drugSubstanceFlag String?
  drugProductFlag   String?
  patentUseCode     String?
  delistFlag        String?
  submissionDate    String?

  @@index([applNo, productNo])
}

model OrangeBookExclusivity {
  id              String    @id @default(cuid())
  applType        String
  applNo          String
  productNo       String
  exclusivityCode String
  exclusivityDate DateTime?

  @@index([applNo, productNo])
}

model KoreanBookProduct {
  id              String  @id @default(cuid())
  seqNo           String?
  adminRoute      String?
  classification  String?
  kfdaClass       String?
  ingredientCode  String?
  ingredientCount String?
  ingredientName  String?
  productCode     String?
  productName     String?
  companyName     String?
  standard        String?
  unit            String?
  price           String?
  type            String?
  note            String?

  mappedIngredient String?
  mappedStrength   String?

  @@index([mappedIngredient, mappedStrength])
  @@index([productName])
}
